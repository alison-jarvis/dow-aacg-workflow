forcefield: openff
water model: None

LJ interaction cutoff, nanometer: 1

periodic box margin, %: 0

aa friction, 1/picosecond: 1
aa integration timestep, femtoseconds: 2
aa equilibration time, nanoseconds: 0.5
aa production time, nanoseconds: 1
aa trajectory log frequency, nanoseconds: 0.001
aa pressure enforcing frequency, nanoseconds: 0.00005

minimization method: srel

nonbonded expression: gamma*kBT*exp(-r^2/(2*(a1*a1 + a2*a2)))
bonded expression: (3*kBT/(2*b*b))*r^2

cg ff parameters: {"nonbonded":{"gamma":{"type":"pairwise","default":1.0,"update":true},"a":{"type":"individual","default":0.3132,"update":false},"kBT": {"type":"fixed","default":1.0,"update":false}},"bonded":{"b":{"type":"pairwise","default":1.0,"update":true},"kBT": {"type":"fixed","default":1.0,"update":false}}}

cg interaction cutoff, nanometer: 0.5

cg friction, 1/picosecond: 1
cg integration timestep, femtoseconds: 20
cg equilibration time, nanoseconds: 1
cg production time, nanoseconds: 3
cg trajectory log frequency, nanoseconds: 0.01
cg pressure enforcing frequency, nanoseconds: 0.001

opt max iterations: 150
opt threshold: 0.005
opt learning rate: 5